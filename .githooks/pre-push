#!/bin/sh
# Pre-push hook: check for .env files, large files, and run sanity checks
# Install: git config core.hooksPath .githooks

echo "--- Pre-push: running pre-push checks ---"

REMOTE="$1"
URL="$2"

FAILED=0

# Check for .env files in the push
ENV_IN_PUSH=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.env(\.|$)' || true)
if [ -n "$ENV_IN_PUSH" ]; then
  echo "[FAIL] .env files detected in push:"
  echo "$ENV_IN_PUSH" | sed 's/^/    /'
  FAILED=1
fi

# Warn about large files (>5MB)
echo "Checking for large files (>5MB)..."
LARGE_FILES=$(git diff --cached --name-only --diff-filter=ACMR | while read -r FILE; do
  if [ -f "$FILE" ]; then
    SIZE=$(wc -c < "$FILE" 2>/dev/null)
    if [ "$SIZE" -gt 5242880 ] 2>/dev/null; then
      echo "$FILE ($(echo "scale=1; $SIZE / 1048576" | bc 2>/dev/null || echo "$SIZE bytes"))"
    fi
  fi
done)

if [ -n "$LARGE_FILES" ]; then
  echo "[WARN] Large files detected (may slow down the repo):"
  echo "$LARGE_FILES" | sed 's/^/    /'
fi

# Quick sanity check: verify git state
if ! git fsck --no-dangling 2>/dev/null; then
  echo "[WARN] Git repository has issues; consider running git gc"
fi

echo ""
if [ "$FAILED" -eq 1 ]; then
  echo "[FAIL] Push blocked: resolve the issues above before pushing."
  exit 1
fi

echo "[PASS] Pre-push checks passed."
exit 0
