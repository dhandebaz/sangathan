#!/bin/sh
# Pre-commit hook: scan staged files for secrets
# Install: git config core.hooksPath .githooks

echo "🔍 Scanning staged files for secrets..."
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED" ]; then
  exit 0
fi

# Check for common secret patterns in staged files
FAILED=0
for FILE in $STAGED; do
  if [ ! -f "$FILE" ]; then
    continue
  fi

  # Skip binary files
  case "$FILE" in
    *.png|*.jpg|*.jpeg|*.gif|*.svg|*.ico|*.woff|*.woff2|*.ttf|*.eot)
      continue
      ;;
  esac

  # Check for potential secrets
  if grep -qE '(sk_live_|sk_test_|ghp_|gho_|xox[bp]-|AKIA[0-9A-Z]{16}|-----BEGIN (RSA |EC )?PRIVATE KEY-----|SG\.[0-9a-zA-Z_-]{20,}\.[0-9a-zA-Z_-]{20,})' "$FILE" 2>/dev/null; then
    echo "❌ Potential secret found in $FILE"
    grep -nE '(sk_live_|sk_test_|ghp_|gho_|xox[bp]-|AKIA[0-9A-Z]{16}|-----BEGIN (RSA |EC )?PRIVATE KEY-----)' "$FILE"
    FAILED=1
  fi
done

if [ "$FAILED" -eq 1 ]; then
  echo "❌ Commit blocked: remove secrets before committing."
  exit 1
fi

echo "✅ No secrets detected in staged files."
